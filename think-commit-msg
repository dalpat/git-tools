#!/bin/bash

set -euo pipefail

MODEL_API="${MODEL_API:-gemini}"
GEMINI_API_KEY="${GEMINI_API_KEY:-}"
GROQ_API_KEY="${GROQ_API_KEY:-}"
GROQ_MODEL="${GROQ_MODEL:-llama-3.1-70b-versatile}"

usage() {
    cat <<EOF
Usage: $(basename "$0") [OPTIONS]

Generate AI-powered commit messages from staged git changes.
Default format: Conventional Commits (https://www.conventionalcommits.org)

Options:
  -s, --simple          Use simple commit message format (not conventional)
  -h, --help            Show this help

Requirements:
  - staged git changes (git add)
  - jq, curl
  - API key (GEMINI_API_KEY or GROQ_API_KEY)

Environment:
  MODEL_API        "gemini" or "groq" (default: gemini)
  GEMINI_API_KEY   Your Gemini API key
  GROQ_API_KEY     Your Groq API key
  GROQ_MODEL       Groq model to use (default: llama-3.1-70b-versatile)

EOF
}

SIMPLE=0

while [[ $# -gt 0 ]]; do
    case "$1" in
        -s|--simple)
            SIMPLE=1
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            usage
            exit 1
            ;;
    esac
done

if [[ -z "$GEMINI_API_KEY" ]] && [[ -z "$GROQ_API_KEY" ]]; then
    echo "Error: Set GEMINI_API_KEY or GROQ_API_KEY env var"
    exit 1
fi

STAGED_FILES=$(git diff --cached --name-only)

if [[ -z "$STAGED_FILES" ]]; then
    echo "Error: No staged changes. Run 'git add' first."
    exit 1
fi

echo "Staged Files:"
echo "-------------"
echo "$STAGED_FILES"
echo ""

GIT_DIFF=$(git diff --cached)

if [[ "$SIMPLE" -eq 1 ]]; then
    PROMPT="Staged files:
$STAGED_FILES

Staged changes:
$GIT_DIFF

Suggest a short, clear Git commit message (imperative mood, max 72 chars)."
else
    PROMPT="Staged files:
$STAGED_FILES

Staged changes:
$GIT_DIFF

Suggest a Git commit message in Conventional Commits format:
- Format: <type>(<scope>): <description>
- Types: feat, fix, docs, style, refactor, test, chore, perf, ci, build
- Use imperative mood, max 72 chars for subject
- If body needed, add blank line after subject

Example: feat(auth): add login endpoint"
fi

if [[ "$MODEL_API" == "gemini" ]]; then
    if [[ -z "$GEMINI_API_KEY" ]]; then
        echo "Error: GEMINI_API_KEY not set"
        exit 1
    fi

    RESPONSE=$(curl -s -X POST \
        "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key=$GEMINI_API_KEY" \
        -H "Content-Type: application/json" \
        -d "{\"contents\": [{\"parts\": [{\"text\": \"$PROMPT\"}]}]}")

    if ! echo "$RESPONSE" | jq -e '.candidates[0].content.parts[0].text' >/dev/null 2>&1; then
        echo "Error: API call failed"
        echo "$RESPONSE"
        exit 1
    fi

    COMMIT_MSG=$(echo "$RESPONSE" | jq -r '.candidates[0].content.parts[0].text')

elif [[ "$MODEL_API" == "groq" ]]; then
    if [[ -z "$GROQ_API_KEY" ]]; then
        echo "Error: GROQ_API_KEY not set"
        exit 1
    fi

    if [[ "$SIMPLE" -eq 1 ]]; then
        SYSTEM_PROMPT="Write short, clear git commit messages in imperative mood, max 72 characters."
    else
        SYSTEM_PROMPT="Write short, clear git commit messages in Conventional Commits format: <type>(<scope>): <description. Types: feat, fix, docs, style, refactor, test, chore, perf, ci, build. Max 72 chars."
    fi

    RESPONSE=$(curl -s -X POST "https://api.groq.com/openai/v1/chat/completions" \
        -H "Authorization: Bearer $GROQ_API_KEY" \
        -H "Content-Type: application/json" \
        -d "{
            \"model\": \"$GROQ_MODEL\",
            \"messages\": [
                {\"role\": \"system\", \"content\": \"$SYSTEM_PROMPT\"},
                {\"role\": \"user\", \"content\": \"$PROMPT\"}
            ]
        }")

    if ! echo "$RESPONSE" | jq -e '.choices[0].message.content' >/dev/null 2>&1; then
        echo "Error: API call failed"
        echo "$RESPONSE"
        exit 1
    fi

    COMMIT_MSG=$(echo "$RESPONSE" | jq -r '.choices[0].message.content')
else
    echo "Error: MODEL_API must be 'gemini' or 'groq'"
    exit 1
fi

echo ""
echo "Suggested Commit Message:"
echo "-------------------------"
echo "$COMMIT_MSG"
echo ""