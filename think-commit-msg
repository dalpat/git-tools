#!/bin/bash

set -euo pipefail

GROQ_API_KEY="${GROQ_API_KEY:-}"
GROQ_MODEL="${GROQ_MODEL:-llama-3.3-70b-versatile}"

usage() {
    cat <<EOF
Usage: $(basename "$0") [OPTIONS]

Generate AI-powered commit messages from staged git changes.
Default format: Conventional Commits (https://www.conventionalcommits.org)

Options:
  -s, --simple          Use simple commit message format (not conventional)
  -v, --verbose         Show staged files before commit message
  -h, --help            Show this help

Requirements:
  - staged git changes (git add)
  - jq, curl
  - GROQ_API_KEY env var

Environment:
  GROQ_API_KEY   Your Groq API key
  GROQ_MODEL     Groq model to use (default: llama-3.3-70b-versatile)

EOF
}

SIMPLE=0
VERBOSE=0

while [[ $# -gt 0 ]]; do
    case "$1" in
        -s|--simple)
            SIMPLE=1
            shift
            ;;
        -v|--verbose)
            VERBOSE=1
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            usage
            exit 1
            ;;
    esac
done

if [[ -z "$GROQ_API_KEY" ]]; then
    echo "Error: Set GROQ_API_KEY env var" >&2
    exit 1
fi

STAGED_FILES=$(git diff --cached --name-only)

if [[ -z "$STAGED_FILES" ]]; then
    echo "Error: No staged changes. Run 'git add' first." >&2
    exit 1
fi

if [[ "$VERBOSE" -eq 1 ]]; then
    echo "Staged Files:"
    echo "-------------"
    echo "$STAGED_FILES"
    echo ""
fi

GIT_DIFF=$(git diff --cached)

if [[ "$SIMPLE" -eq 1 ]]; then
    PROMPT="Staged files:
$STAGED_FILES

Staged changes:
$GIT_DIFF

Generate ONLY the commit message. Nothing else. No explanation, no code blocks, no prefixes.
Format: short description in imperative mood (max 72 chars).
Example: add login endpoint"
else
    PROMPT="Staged files:
$STAGED_FILES

Staged changes:
$GIT_DIFF

Generate ONLY the commit message. Nothing else. No explanation, no code blocks, no prefixes.
Format: Conventional Commits <type>(<scope>): <description>
Types: feat, fix, docs, style, refactor, test, chore, perf, ci, build
Rules: imperative mood, max 72 chars, no body.
Example: feat(auth): add login endpoint"
fi

if [[ "$SIMPLE" -eq 1 ]]; then
    SYSTEM_PROMPT="Generate ONLY the commit message. No explanation, no code blocks, no prefixes. Short description in imperative mood, max 72 chars."
else
    SYSTEM_PROMPT="Generate ONLY the commit message in Conventional Commits format. No explanation, no code blocks, no prefixes. Format: <type>(<scope>): <description. Types: feat, fix, docs, style, refactor, test, chore. Max 72 chars."
fi

JSONPayload=$(jq -n \
    --arg model "$GROQ_MODEL" \
    --arg system "$SYSTEM_PROMPT" \
    --arg user "$PROMPT" \
    '{"model": $model, "messages": [{"role": "system", "content": $system}, {"role": "user", "content": $user}]}')

RESPONSE=$(curl -s -X POST "https://api.groq.com/openai/v1/chat/completions" \
    -H "Authorization: Bearer $GROQ_API_KEY" \
    -H "Content-Type: application/json" \
    -d "$JSONPayload")

if ! echo "$RESPONSE" | jq -e '.choices[0].message.content' >/dev/null 2>&1; then
    echo "Error: API call failed" >&2
    echo "$RESPONSE" >&2
    exit 1
fi

COMMIT_MSG=$(echo "$RESPONSE" | jq -r '.choices[0].message.content')

printf '%s' "$COMMIT_MSG"