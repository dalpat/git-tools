#!/bin/bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIB_PATH="${SCRIPT_DIR}/think-tools-lib.sh"

if [[ -f "$LIB_PATH" ]]; then
    source "$LIB_PATH"
    load_config
    load_project_config
else
    GROQ_API_KEY="${GROQ_API_KEY:-}"
    GROQ_MODEL="${GROQ_MODEL:-llama-3.3-70b-versatile}"
    
    if [[ -f "${HOME}/.think-tools.json" ]]; then
        GROQ_API_KEY="${GROQ_API_KEY:-$(jq -r '.api_key // empty' "${HOME}/.think-tools.json" 2>/dev/null || echo "")}"
        GROQ_MODEL="${GROQ_MODEL:-$(jq -r '.model // "llama-3.3-70b-versatile"' "${HOME}/.think-tools.json" 2>/dev/null || echo "llama-3.3-70b-versatile")}"
    fi
    
    REVIEW_BATCH_SIZE="${REVIEW_BATCH_SIZE:-3}"
    REVIEW_RETRY="${REVIEW_RETRY:-2}"
    FOCUS_SECURITY="${FOCUS_SECURITY:-true}"
    FOCUS_STYLE="${FOCUS_STYLE:-true}"
    FOCUS_BEST_PRACTICES="${FOCUS_BEST_PRACTICES:-true}"
fi

if [[ -f "$LIB_PATH" ]]; then
    ensure_review_cache >/dev/null
fi

usage() {
    cat <<EOF
Usage: $(basename "$0") [OPTIONS]

Review staged changes using AI-powered code review.
Reads staged changes by default, falls back to unstaged if none staged.

Options:
  -l, --list           List available Groq models
  -m, --model MODEL    Use specific model (default: llama-3.3-70b-versatile)
  -r, --retry N        Number of retries on failure (default: ${REVIEW_RETRY:-2})
  -b, --batch-size N  Number of files per batch (default: ${REVIEW_BATCH_SIZE:-3})
  -a, --all            Enable all focus areas (default)
  -s, --security       Focus on security vulnerabilities only
  -t, --style          Focus on code style only
  -p, --best-practices Focus on best practices only
  -v, --verbose        Show diff being reviewed before output
  -h, --help           Show this help

Config resolution order (highest wins):
  1. CLI flags
  2. .think-reviewrc (project)
  3. ~/.think-tools.json (defaults)

Multiple focus flags can be combined (e.g., --security --style).

Requirements:
  - git changes (staged or unstaged)
  - jq, curl
  - GROQ_API_KEY env var or ~/.think-tools.json

Output:
  Markdown format with file:line references

EOF
}

LIST_MODELS=0
RETRY_COUNT="${REVIEW_RETRY:-2}"
BATCH_SIZE="${REVIEW_BATCH_SIZE:-3}"
FOCUS_ALL=0
FOCUS_SECURITY_CLI="false"
FOCUS_STYLE_CLI="false"
FOCUS_BEST_PRACTICES_CLI="false"
VERBOSE=0
INTERACTIVE=0

while [[ $# -gt 0 ]]; do
    case "$1" in
        -l|--list)
            LIST_MODELS=1
            shift
            ;;
        -m|--model)
            GROQ_MODEL="$2"
            shift 2
            ;;
        -r|--retry)
            RETRY_COUNT="$2"
            shift 2
            ;;
        -b|--batch-size)
            BATCH_SIZE="$2"
            shift 2
            ;;
        -a|--all)
            FOCUS_ALL=1
            FOCUS_SECURITY_CLI="true"
            FOCUS_STYLE_CLI="true"
            FOCUS_BEST_PRACTICES_CLI="true"
            shift
            ;;
        -s|--security)
            FOCUS_ALL=0
            FOCUS_SECURITY_CLI="true"
            shift
            ;;
        -t|--style)
            FOCUS_ALL=0
            FOCUS_STYLE_CLI="true"
            shift
            ;;
        -p|--best-practices)
            FOCUS_ALL=0
            FOCUS_BEST_PRACTICES_CLI="true"
            shift
            ;;
        -v|--verbose)
            VERBOSE=1
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            usage
            exit 1
            ;;
    esac
done

FOCUS_AREAS=""
if [[ "$FOCUS_ALL" -eq 1 ]] || { [[ "$FOCUS_SECURITY_CLI" == "true" ]] && [[ "$FOCUS_STYLE_CLI" == "true" ]] && [[ "$FOCUS_BEST_PRACTICES_CLI" == "true" ]]; }; then
    FOCUS_AREAS="security, style, and best practices"
elif [[ "$FOCUS_SECURITY_CLI" == "true" ]] && [[ "$FOCUS_STYLE_CLI" == "true" ]]; then
    FOCUS_AREAS="security and style"
elif [[ "$FOCUS_SECURITY_CLI" == "true" ]] && [[ "$FOCUS_BEST_PRACTICES_CLI" == "true" ]]; then
    FOCUS_AREAS="security and best practices"
elif [[ "$FOCUS_STYLE_CLI" == "true" ]] && [[ "$FOCUS_BEST_PRACTICES_CLI" == "true" ]]; then
    FOCUS_AREAS="style and best practices"
elif [[ "$FOCUS_SECURITY_CLI" == "true" ]]; then
    FOCUS_AREAS="security"
elif [[ "$FOCUS_STYLE_CLI" == "true" ]]; then
    FOCUS_AREAS="style"
elif [[ "$FOCUS_BEST_PRACTICES_CLI" == "true" ]]; then
    FOCUS_AREAS="best practices"
else
    FOCUS_AREAS="security, style, and best practices"
fi

if [[ -z "$GROQ_API_KEY" ]]; then
    echo "Error: Set GROQ_API_KEY env var or create ~/.think-tools.json" >&2
    exit 1
fi

if [[ "$LIST_MODELS" -eq 1 ]]; then
    RESPONSE=$(curl -s "https://api.groq.com/openai/v1/models" \
        -H "Authorization: Bearer $GROQ_API_KEY")
    
    if ! echo "$RESPONSE" | jq -e '.data' >/dev/null 2>&1; then
        echo "Error: Failed to fetch models" >&2
        echo "$RESPONSE" >&2
        exit 1
    fi
    
    echo "$RESPONSE" | jq -r '.data[] | "\(.id)"' | sort
    exit 0
fi

STAGED_DIFF=$(git diff --cached)
STAGED_FILES=$(git diff --cached --name-only)

if [[ -n "$STAGED_FILES" ]]; then
    DIFF="$STAGED_DIFF"
    DIFF_TYPE="staged"
    ALL_FILES=("$STAGED_FILES")
else
    DIFF=$(git diff)
    DIFF_FILES=$(git diff --name-only)
    
    if [[ -z "$DIFF_FILES" ]]; then
        echo "Error: No staged or unstaged changes to review" >&2
        exit 1
    fi
    
    DIFF="$DIFF"
    DIFF_TYPE="unstaged"
    ALL_FILES=("$DIFF_FILES")
fi

readarray -t FILE_LIST < <(printf '%s\n' "${ALL_FILES[@]}")
FILE_COUNT="${#FILE_LIST[@]}"

process_batch() {
    local batch_files=("$@")
    local batch_diff=""
    
    for file in "${batch_files[@]}"; do
        if [[ "$DIFF_TYPE" == "staged" ]]; then
            batch_diff+=$(git diff --cached -- "$file")
        else
            batch_diff+=$(git diff -- "$file")
        fi
        batch_diff+=$'\n'
    done
    
    local batch_system_prompt="You are a senior code reviewer. Review the following git diff and provide feedback on: ${FOCUS_AREAS}. Output in markdown format with inline file:line references. Group feedback by enabled category. Keep feedback concise and actionable."
    
    local batch_user_prompt="Review the following diff for $DIFF_TYPE changes:

$batch_diff

Provide feedback in this format for each enabled category:
## [Category Name]
- \`filename:line\` - Issue description

If no issues found in a category, omit that section."
    
    if [[ -f "$LIB_PATH" ]]; then
        call_groq "$GROQ_MODEL" "$batch_system_prompt" "$batch_user_prompt" "$RETRY_COUNT" "true"
    else
        local batch_payload
        batch_payload=$(jq -n \
            --arg model "$GROQ_MODEL" \
            --arg system "$batch_system_prompt" \
            --arg user "$batch_user_prompt" \
            '{"model": $model, "messages": [{"role": "system", "content": $system}, {"role": "user", "content": $user}]}')
        
        local attempt=0
        local response
        while [[ $attempt -lt "$RETRY_COUNT" ]]; do
            attempt=$((attempt + 1))
            response=$(curl -s -X POST "https://api.groq.com/openai/v1/chat/completions" \
                -H "Authorization: Bearer $GROQ_API_KEY" \
                -H "Content-Type: application/json" \
                -d "$batch_payload")
            
            if echo "$response" | jq -e '.choices[0].message.content' >/dev/null 2>&1; then
                echo "$response"
                return 0
            fi
            
            if [[ $attempt -lt "$RETRY_COUNT" ]]; then
                sleep 1
            fi
        done
        
        read -p "Retry again? [y/n] " -n 1 -r reply
        echo
        if [[ "$reply" =~ ^[Yy]$ ]]; then
            process_batch "${batch_files[@]}"
            return $?
        fi
        
        echo "$response" >&2
        return 1
    fi
}

REVIEW_OUTPUT=""

if [[ "$FILE_COUNT" -gt "$BATCH_SIZE" ]] && [[ "$BATCH_SIZE" -gt 0 ]]; then
    local batch_num=0
    for ((i=0; i<FILE_COUNT; i+=BATCH_SIZE)); do
        batch_num=$((batch_num + 1))
        local batch=("${FILE_LIST[@]:$i:$BATCH_SIZE}")
        
        if [[ "$batch_num" -gt 1 ]]; then
            REVIEW_OUTPUT+=$'\n---\n'$'\n'
        fi
        
        local batch_response
        batch_response=$(process_batch "${batch[@]}")
        
        if echo "$batch_response" | jq -e '.choices[0].message.content' >/dev/null 2>&1; then
            REVIEW_OUTPUT+=$(echo "$batch_response" | jq -r '.choices[0].message.content')
        else
            REVIEW_OUTPUT+="Batch $batch_num error: $(echo "$batch_response" | jq -r '.error.message // "API failure"')"
        fi
    done
else
    SYSTEM_PROMPT="You are a senior code reviewer. Review the following git diff and provide feedback on: ${FOCUS_AREAS}. Output in markdown format with inline file:line references. Group feedback by enabled category. Keep feedback concise and actionable."
    
    USER_PROMPT="Review the following diff for $DIFF_TYPE changes:

$DIFF

Provide feedback in this format for each enabled category:
## [Category Name]
- \`filename:line\` - Issue description

If no issues found in a category, omit that section."
    
    if [[ -f "$LIB_PATH" ]]; then
        RESPONSE=$(call_groq "$GROQ_MODEL" "$SYSTEM_PROMPT" "$USER_PROMPT" "$RETRY_COUNT" "true")
    else
        JSONPayload=$(jq -n \
            --arg model "$GROQ_MODEL" \
            --arg system "$SYSTEM_PROMPT" \
            --arg user "$USER_PROMPT" \
            '{"model": $model, "messages": [{"role": "system", "content": $system}, {"role": "user", "content": $user}]}')
        
        local attempt=0
        local response
        while [[ $attempt -lt "$RETRY_COUNT" ]]; do
            attempt=$((attempt + 1))
            response=$(curl -s -X POST "https://api.groq.com/openai/v1/chat/completions" \
                -H "Authorization: Bearer $GROQ_API_KEY" \
                -H "Content-Type: application/json" \
                -d "$JSONPayload")
            
            if echo "$response" | jq -e '.choices[0].message.content' >/dev/null 2>&1; then
                RESPONSE="$response"
                break
            fi
            
            if [[ $attempt -lt "$RETRY_COUNT" ]]; then
                sleep 1
            fi
        done
        
        read -p "Retry again? [y/n] " -n 1 -r reply
        echo
        if [[ "$reply" =~ ^[Yy]$ ]]; then
            JSONPayload=$(jq -n \
                --arg model "$GROQ_MODEL" \
                --arg system "$SYSTEM_PROMPT" \
                --arg user "$USER_PROMPT" \
                '{"model": $model, "messages": [{"role": "system", "content": $system}, {"role": "user", "content": $user}]}')
            
            RESPONSE=$(curl -s -X POST "https://api.groq.com/openai/v1/chat/completions" \
                -H "Authorization: Bearer $GROQ_API_KEY" \
                -H "Content-Type: application/json" \
                -d "$JSONPayload")
        fi
    fi
    
    if ! echo "$RESPONSE" | jq -e '.choices[0].message.content' >/dev/null 2>&1; then
        echo "Error: API call failed" >&2
        echo "$RESPONSE" >&2
        exit 1
    fi
    
    REVIEW_OUTPUT=$(echo "$RESPONSE" | jq -r '.choices[0].message.content')
fi

if [[ "$VERBOSE" -eq 1 ]]; then
    echo "## Diff being reviewed ($DIFF_TYPE changes):"
    echo ""
    echo '```diff'
    echo "$DIFF"
    echo '```'
    echo ""
    echo "---"
    echo ""
fi

printf '%s' "$REVIEW_OUTPUT"